APP_NAME=FastAPI Project
DEBUG=true
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5437/fastapi_project
POSTGRES_DB=fastapi_project
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin
DB_STARTUP_RETRIES=10
DB_STARTUP_RETRY_DELAY=2.0

PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=fastapi-docs
CHAT_SEMANTIC_TOP_K=3
CHAT_SEMANTIC_NAMESPACE_PREFIX=chat-memory
REDIS_URL=redis://localhost:6382/0
CHAT_CACHE_KEY_PREFIX=chat-cache
CHAT_CACHE_SESSION_MESSAGE_LIMIT=20
CHAT_CACHE_MAX_SESSIONS=2000
CHAT_CACHE_SESSION_TTL_SECONDS=86400
CHAT_CACHE_FLUSH_BATCH_SIZE=100